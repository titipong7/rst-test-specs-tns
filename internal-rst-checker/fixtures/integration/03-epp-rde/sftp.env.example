# SFTP credentials for the RDE side of the EPP -> RDE integration test.
# Replace each value with your own escrow SFTP test setup.
INTEGRATION_RDE_SFTP_HOSTNAME=sftp.rsp.example
INTEGRATION_RDE_SFTP_USERNAME=icann
INTEGRATION_RDE_SFTP_DIRECTORY=/test/deposits
INTEGRATION_RDE_SFTP_PUBLIC_KEY_PATH=<path-to-rde-sftp-pubkey.pub>
